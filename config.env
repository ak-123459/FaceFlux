# ─────────────────────────────────────────────────────────────────────────────
# config.env
# PRISM — Distributed Face Recognition Pipeline
# ─────────────────────────────────────────────────────────────────────────────
#
# HOW TO USE
# ──────────
# Each machine only needs the section that matches its role.
# Copy this file to your machine, rename to .env, and uncomment
# only the section for your machine's role.
#
# MACHINE ROLES
# ─────────────────────────────────────────────────────
#  Machine 1 — Capture       runs: capture_service.py
#  Machine 2 — Inference     runs: inference_api.py
#  Machine 3 — Vector Store  runs: vector_store_api (main.py)
#  Machine 4 — SQL Store     runs: MariaDB only (no Python)
# ─────────────────────────────────────────────────────
#
# NETWORK MAP (update IPs to match your actual machines)
# ─────────────────────────────────────────────────────
#  Machine 1 Capture       192.168.1.10
#  Machine 2 Inference     192.168.1.20
#  Machine 3 Vector Store  192.168.1.30
#  Machine 4 SQL / MariaDB 192.168.1.40
# ─────────────────────────────────────────────────────


# ═════════════════════════════════════════════════════════════════════════════
# MACHINE 1 — CAPTURE SERVICE
# Copy this block to Machine 1's .env
# ═════════════════════════════════════════════════════════════════════════════

# Where to send cropped faces for inference
INFERENCE_HOST=192.168.1.20
INFERENCE_PORT=8004

# How many cameras this machine handles
CAMERA_IDS=cam_01,cam_02,cam_03

# Camera sources (RTSP streams or USB index)
CAMERA_cam_01_SOURCE=rtsp://admin:pass@192.168.1.101/stream
CAMERA_cam_02_SOURCE=rtsp://admin:pass@192.168.1.102/stream
CAMERA_cam_03_SOURCE=rtsp://admin:pass@192.168.1.103/stream

# How many frames per second to process per camera (reduce to save bandwidth)
CAPTURE_FPS_CAP=5

# Max faces to buffer before sending batch
CAPTURE_BATCH_SIZE=8

# JPEG quality for crop compression (lower = smaller = faster transfer)
CAPTURE_JPEG_QUALITY=85


# ═════════════════════════════════════════════════════════════════════════════
# MACHINE 2 — INFERENCE API
# Copy this block to Machine 2's .env
# ═════════════════════════════════════════════════════════════════════════════

# This service binding
EMB_MODEL_HOST=0.0.0.0
EMB_MODEL_PORT=8004
EMB_NUM_WORKER=1                          # always 1 on Windows

# ONNX model
EMB_MODEL_PATH=models/w600k_r50_int8.onnx

# Thread pool for blocking work (ONNX, DB calls, decode)
THREAD_POOL_SIZE=4

# Max images per batch request
MAX_BATCH_SIZE=64

# Default camera ID (can be overridden per request)
CAMERA_ID=cam_01

# ── Vector Store (Machine 3) ──────────────────────────────────────────────
VECTOR_DB_HOST=192.168.1.30
VECTOR_DB_PORT=8005
VECTOR_STORE_TIMEOUT=5.0

# ── SQL Database (Machine 4) ──────────────────────────────────────────────
DB_HOST=192.168.1.40
DB_PORT=3306
DB_USER=frs_user
DB_PASSWORD=your_password_here
DB_NAME=attendance_db
DB_POOL_SIZE=5


# ═════════════════════════════════════════════════════════════════════════════
# MACHINE 3 — VECTOR STORE API
# Copy this block to Machine 3's .env
# ═════════════════════════════════════════════════════════════════════════════

# This service binding
VECTOR_DB_HOST=0.0.0.0
VECTOR_DB_PORT=8005
VECTOR_DB_WORKER=1                        # always 1 on Windows

# FAISS index storage (local to this machine)
FAISS_INDEX_PATH=data/faiss.index
FAISS_META_PATH=data/faiss_meta.pkl

# Matching config
MATCH_THRESHOLD=0.40                      # L2 distance — lower = stricter
TOP_K=1                                   # return top N candidates

# Thread pool for FAISS operations
FAISS_THREAD_WORKERS=4

# Read-only mode — set true if running a replica for load balancing
# Replica will serve /search /batch /verify but reject /register /upsert /delete
VECTOR_STORE_READ_ONLY=false


# ═════════════════════════════════════════════════════════════════════════════
# MACHINE 4 — SQL STORE (MariaDB only — no Python service needed)
# Run these SQL commands once on Machine 4 to allow remote connections
# ═════════════════════════════════════════════════════════════════════════════
#
# Step 1 — Install MariaDB if not already installed
#   Windows: https://mariadb.org/download/
#   Linux:   sudo apt install mariadb-server
#
# Step 2 — Create database and user
#   Run in MariaDB shell (mysql -u root -p):
#
#   CREATE DATABASE IF NOT EXISTS attendance_db
#     CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
#
#   CREATE USER IF NOT EXISTS 'frs_user'@'%'
#     IDENTIFIED BY 'your_password_here';
#
#   GRANT ALL PRIVILEGES ON attendance_db.*
#     TO 'frs_user'@'%';
#
#   FLUSH PRIVILEGES;
#
# Step 3 — Allow remote connections
#   Edit /etc/mysql/mariadb.conf.d/50-server.cnf (Linux)
#   or   C:\Program Files\MariaDB\data\my.ini    (Windows)
#
#   Change:
#     bind-address = 127.0.0.1
#   To:
#     bind-address = 0.0.0.0
#
# Step 4 — Open firewall port
#   Windows: netsh advfirewall firewall add rule name="MariaDB"
#            protocol=TCP dir=in localport=3306 action=allow
#   Linux:   sudo ufw allow 3306/tcp
#
# Step 5 — Restart MariaDB
#   Windows: net stop MariaDB && net start MariaDB
#   Linux:   sudo systemctl restart mariadb
#
# Step 6 — Test from Machine 2
#   python -c "
#   from database.database import init_database
#   init_database(
#       host='192.168.1.40', port=3306,
#       user='frs_user', password='your_password_here',
#       database='attendance_db'
#   )
#   print('DB OK')
#   "